# .env example

# Port used by FastAPI (default = 4173)
API_PORT=4173

# Hostname used by FastAPI (default = localhost)
API_HOST=127.0.0.1

# Path to manifest.hocon used by NeuroSan and FastAPI (default = "registries/manifest.hocon")
AGENT_MANIFEST_FILE=registries/manifest.hocon

# Path to coded_tools used by NeuroSan and FastAPI (default = coded_tools)
AGENT_TOOL_PATH=coded_tools

# Examples of a hosted neuro-san server hostname
NEURO_SAN_SERVER_HOST=127.0.0.1

# Examples of a neuro-san server port
NEURO_SAN_SERVER_HTTP_PORT=8080

# Allow the browser (nsflow web client) to call the neuro-san HTTP server cross-origin.
# neuro-san only sends Access-Control-* (CORS) headers when this is set. nsflow sets it
# automatically for a neuro-san server it launches itself; set it here (any non-empty value)
# when pointing nsflow at an externally-hosted neuro-san server.
AGENT_ALLOW_CORS_HEADERS=1
